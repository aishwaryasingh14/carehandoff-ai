# MIMIC-IV data — excluded entirely. MIMIC is gated by a PhysioNet Data Use
# Agreement that prohibits redistribution, even of de-identified data.
# Users must obtain their own credentialed copy from physionet.org and
# place the files under data/raw/mimic/ themselves.
data/raw/mimic/

# Clinical guideline documents are included in this repo (data/raw/guidelines/).

# Revised notes output — may contain patient data
data/revised_notes.csv

